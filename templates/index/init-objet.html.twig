{% extends 'base.html.twig' %}

{% block title %}Configuration des étapes
{% endblock %}

{% block body %}
	{# Fil d'arianne #}
	<nav role="navigation" class="fr-breadcrumb" aria-label="vous êtes ici :">
		<button type="button" class="fr-breadcrumb__button" aria-expanded="false" aria-controls="breadcrumb">Voir le fil d&#39;arianne</button>

		<div class="fr-collapse" id="breadcrumb">
			<ol class="fr-breadcrumb__list">
				<li>
					<a class="fr-breadcrumb__link" href="{{ path('transit_index') }}">Page d'accueil</a>
				</li>
				<li>
					<a class="fr-breadcrumb__link" aria-current="page">Configuration des étapes</a>
				</li>
			</ol>
		</div>
	</nav>
	{# Fin fil d'arianne #}

	<main class="fr-mt-4w">

		<h2>Configuration des étapes pour "{{ objet.libelle }}"</h2>

		<p>
			Vous avez saisi l'objet&nbsp;"<span class="bold">{{ objet.libelle }}</span>":
			<br>
			Cet objet n'a pas encore été configuré. Nous allons donc le paramétrer...
		</p>

		<p>
			Dans les champs ci-dessous, saisissez une action à réaliser lorsque cet objet ({{ objet.libelle }}) est choisi.
			<br>
			En face, indiquer le statut de l'envoi tant que cette action n'est pas accomplie, puis cliquez sur "Ajouter".
			<br>
			Une liste d'actions va ainsi être créée. Vous pourrez-alors réagencer l'ordre des actions par glisser-déposer, modifier les actions et statuts en cliquant dessus, ou supprimer une action avec le bouton "Suppr.".
		</p>

		{# Le code ci-dessous a été généré avec Gemini, et adapté à ce projet #}

		<div class="todo-container fr-grid-row fr-grid-row--gutters fr-mb-4w">

			<div class="fr-input-group fr-col-5">
				<label class="fr-label" for="taskInput">
					Action à réaliser
				</label>
				<input class="fr-input" aria-describedby="taskInput-messages" id="taskInput" type="text" placeholder="Avez-vous saisi les documents?">
				<div class="fr-messages-group" id="taskInput-messages" aria-live="polite"></div>
			</div>

			<div class="fr-input-group fr-col-5">
				<label class="fr-label" for="statusInput">
					Statut si non réalisé
				</label>
				<input class="fr-input" list="statusSuggestions" aria-describedby="statusInput-messages" id="statusInput" type="text">
				<div class="fr-messages-group" id="statusInput-messages" placeholder="Doc à finaliser..." aria-live="polite"></div>
				<datalist id="statusSuggestions">
					{% for statut in statuts %}
						<option value="{{ statut.libelle }}"></option>
					{% endfor %}
				</datalist>
			</div>

			<div class="fr-input-group fr-col-2">
				<button id="add-task-button" class="fr-mt-4w fr-btn fr-btn--tertiary fr-icon-add-line fr-btn--icon-left">Ajouter</button>
			</div>

			<h3 class="fr-h6 fr-col-5 fr-col-offset-1 inline center">Action à réaliser</h3>
			<h3 class="fr-h6 fr-col-4 inline center">Statut si non réalisé</h3>
			<h3 class="fr-h6 fr-col-1 inline center">Action</h3>

			<ul id="todoList" class="todo-list fr-container"></ul>

			<button id="sauver-objet-button" data-id="{{ objet.id }}" type="button" disabled class="fr-btn fr-mt-2w">
				Enregistrer cette configuration
				<div class="loader fr-hidden" id="sauver-objet-button--loader">
					<svg version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px" width="40px" height="40px" viewbox="0 0 40 40" enable-background="new 0 0 40 40" xml:space="preserve">
						<path opacity="1" fill="#fff" d="M20.201,5.169c-8.254,0-14.946,6.692-14.946,14.946c0,8.255,6.692,14.946,14.946,14.946
																																																																																																																																																																																																																																																																																																																											            s14.946-6.691,14.946-14.946C35.146,11.861,28.455,5.169,20.201,5.169z M20.201,31.749c-6.425,0-11.634-5.208-11.634-11.634
																																																																																																																																																																																																																																																																																																																											          c0-6.425,5.209-11.634,11.634-11.634c6.425,0,11.633,5.209,11.633,11.634C31.834,26.541,26.626,31.749,20.201,31.749z"/>
						<path fill="#000" d="M26.013,10.047l1.654-2.866c-2.198-1.272-4.743-2.012-7.466-2.012h0v3.312h0
																																																																																																																																																																																																																																																																																																																																																																								            C22.32,8.481,24.301,9.057,26.013,10.047z">
							<animateTransform attributetype="xml" attributename="transform" type="rotate" from="0 20 20" to="360 20 20" dur="0.5s" repeatcount="indefinite"/>
						</path>
					</svg>
				</div>
			</button>

		</div>

	</main>

{% endblock %}
